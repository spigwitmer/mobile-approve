# Example .env file for the docker-compose broker (Path B).
# Copy this to .env (gitignored) and fill in the real values. Run
# `bin/setup-broker.sh` to generate .env automatically from your
# existing ~/.config/opencode/opencode.json.
#
# All variables listed here are required by the broker service in
# compose.yaml (the :?required suffix in the YAML makes compose fail
# to start if any of them is missing).

# Public URL for the review page (Tailscale MagicDNS or similar).
# Must match the tunnel.publicBaseUrl in the mobile-approve plugin
# entry in ~/.config/opencode/opencode.json.
MOBILE_APPROVE_PUBLIC_URL=https://your-host.tailnet.ts.net

# ntfy server + topic + credentials. The user must have read-write
# permission on the topic (the pub-mobile-approve user with the
# oc-* ACL, configured by bin/setup-ntfy.sh).
MOBILE_APPROVE_NTFY_BASE_URL=https://your-host.tailnet.ts.net
MOBILE_APPROVE_NTFY_TOPIC=oc-CHANGEME
MOBILE_APPROVE_NTFY_USER=pub-mobile-approve
MOBILE_APPROVE_NTFY_PASSWORD=tk_CHANGEME
